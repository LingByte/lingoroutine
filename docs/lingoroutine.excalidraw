    {
      "id": "UTDa5yn0tOALdj8TqonlC",
      "type": "text",
      "x": -4488.103947716983,
      "y": 53.79019598956994,
      "width": 226.59197998046875,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
